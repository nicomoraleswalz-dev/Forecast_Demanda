                                </div>
                              </td>
                              <td className="py-2 pr-3 text-xs" style={{ color: COLORS.inkMuted }}>{a.comment || "—"}</td>
                              <td className="py-2 pr-3">
                                <input type="number" min="0" placeholder="—"
                                  value={a.actual ?? ""}
                                  onChange={(e) => setSavedAdjustments((p) => p.map((x) => x.id === a.id ? { ...x, actual: e.target.value === "" ? null : Number(e.target.value) } : x))}
                                  className="w-20 border rounded px-1 py-0.5 text-xs font-mono text-right"
                                  style={{ borderColor: COLORS.border }} />
                              </td>
                              <td className="py-2 pr-3 text-right">
                                {fva != null
                                  ? <span className="text-xs font-bold" style={{ color: v.color }}>{fva >= 0 ? "+" : ""}{(fva * 100).toFixed(1)}pp</span>
                                  : <span className="text-xs" style={{ color: COLORS.inkMuted }}>pendiente</span>}
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                </Card>
              )}

              {/* HISTORIAL FVA DETALLADO (backtest simulado) */}
              <Card>
                <Eyebrow>Historial de ajustes simulados (período de backtest)</Eyebrow>
                <p className="text-xs mt-1 mb-3" style={{ color: COLORS.inkMuted }}>
                  Estos datos se generan automáticamente usando el período de holdout para que puedas ver cómo habría funcionado el sistema.
                  Los ajustes reales guardados arriba se sumarán aquí una vez que ingreses el resultado.
                </p>
                <div className="overflow-x-auto">
                  <table className="w-full text-xs">
                    <thead>
                      <tr className="text-left border-b" style={{ color: COLORS.inkMuted, borderColor: COLORS.border }}>
                        <th className="py-2 pr-3 font-medium">SKU</th>
                        <th className="py-2 pr-3 font-medium">Mes</th>
                        <th className="py-2 pr-3 font-medium">Colaborador</th>
                        <th className="py-2 pr-3 font-medium text-right">Estadístico</th>
                        <th className="py-2 pr-3 font-medium text-right">Ajustado</th>
                        <th className="py-2 pr-3 font-medium text-right">Real</th>
                        <th className="py-2 pr-3 font-medium text-right">Error stat.</th>
                        <th className="py-2 pr-3 font-medium text-right">Error ajuste</th>
                        <th className="py-2 pr-3 font-medium text-right">FVA</th>
                      </tr>
                    </thead>
                    <tbody>
                      {historicalFVA.slice(0, 40).map((r, i) => {
                        const errStat = Math.abs(r.actual - r.statistical);
                        const errAdj  = Math.abs(r.actual - r.adjusted);
                        const fva = r.actual > 0 ? (errStat - errAdj) / r.actual : null;
                        const def = COLLAB_DEFS.find((c) => c.name === r.collaborator);
                        return (
                          <tr key={i} className="border-b" style={{ borderColor: COLORS.grid }}>
                            <td className="py-1.5 pr-3 font-semibold" style={{ color: COLORS.ink }}>{r.sku}</td>
                            <td className="py-1.5 pr-3 font-mono" style={{ color: COLORS.inkMuted }}>{r.monthLbl}</td>
                            <td className="py-1.5 pr-3">
                              <div className="flex items-center gap-1">
                                <div className="w-4 h-4 rounded-full flex items-center justify-center text-[9px] font-bold text-white" style={{ background: def?.color || COLORS.graphite }}>{r.collaborator.charAt(0)}</div>
                                <span style={{ color: COLORS.ink }}>{r.collaborator}</span>
                              </div>
                            </td>
                            <td className="py-1.5 pr-3 font-mono text-right">{fmt(r.statistical, 0)}</td>
                            <td className="py-1.5 pr-3 font-mono text-right">{fmt(r.adjusted, 0)}</td>
                            <td className="py-1.5 pr-3 font-mono text-right">{fmt(r.actual, 0)}</td>
                            <td className="py-1.5 pr-3 font-mono text-right" style={{ color: COLORS.inkMuted }}>{fmt(errStat, 0)}</td>
                            <td className="py-1.5 pr-3 font-mono text-right" style={{ color: errAdj < errStat ? COLORS.accent : COLORS.brick }}>{fmt(errAdj, 0)}</td>
                            <td className="py-1.5 pr-3 font-mono text-right font-bold" style={{ color: fva != null && fva > 0 ? COLORS.accent : COLORS.brick }}>
                              {fva != null ? `${fva >= 0 ? "+" : ""}${(fva * 100).toFixed(1)}pp` : "—"}
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                  {historicalFVA.length > 40 && (
                    <p className="text-xs mt-2" style={{ color: COLORS.inkMuted }}>Mostrando 40 de {historicalFVA.length} registros.</p>
                  )}
                </div>
              </Card>
            </div>
          )}
        </div>
      )}
    </div>
  );
}
