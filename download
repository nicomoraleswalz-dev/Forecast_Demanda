  }, [skuData]);

  const structuralAlerts = useMemo(() => {
    if (!skuData) return {};
    const out = {};
    for (const sku in skuData) out[sku] = detectStructuralChange(skuData[sku].series, skuData[sku].dates);
    return out;
  }, [skuData]);

  const lifecycle = useMemo(() => {
    if (!skuData) return {};
    const out = {};
    for (const sku in skuData) out[sku] = detectLifecycle(skuData[sku].series, skuData[sku].dates);
    return out;
  }, [skuData]);

  const effectiveSeries = useMemo(() => {
    if (!skuData) return {};
    const out = {};
    for (const sku in skuData) {
      let s = skuData[sku].series;
      // 1. Limpieza de outliers
      if (useCleanData[sku] && allOutliers[sku]?.length) s = applyClean(s, allOutliers[sku]);
      // 2. Normalización de promociones históricas
      if (promoHist[sku] && promoHist[sku].size > 0) s = applyPromoBaseline(s, promoHist[sku]);
      out[sku] = s;
    }
    return out;
  }, [skuData, useCleanData, allOutliers, promoHist]);

  const abcxyz = useMemo(() => {
    if (!skuData) return null;
    return classifyABCXYZ(skuData);
  }, [skuData]);

  const analysis = useMemo(() => {
    if (!skuData) return null;
    const out = {};
    for (const sku in skuData) out[sku] = runBacktest(effectiveSeries[sku]);
    return out;
  }, [effectiveSeries]);

  const inventoryRows = useMemo(() => {
    if (!skuData || !analysis || !abcxyz) return null;
    return Object.keys(skuData).map((sku) => {
      const s = effectiveSeries[sku];
      const usedKey = modelOverrides[sku] || analysis[sku].winnerKey;
      const fc = finalForecast(s, usedKey, 12);
      const forecast12 = fc ? fc.forecastFull : [];
      const abc = abcxyz[sku]?.abc || "C";
      const lt = ltOverrides[sku] != null ? ltOverrides[sku] : globalLT;
      const sl = useAbcSL ? SL_BY_ABC[abc] : globalSL;
      const metrics = calcInventory(s, forecast12, lt, sl, globalReview);
      const cs = currentStock[sku] != null ? Number(currentStock[sku]) : null;
      const gap = cs != null ? cs - metrics.rop : null;
      const suggestedOrder = cs != null ? Math.max(0, metrics.maxStock - cs) : null;
      const stockMonths = cs != null && metrics.avgDemand > 0 ? (cs / metrics.avgDemand).toFixed(1) : null;
      const fcSum = forecast12.reduce((a, b) => a + b, 0);
      const coverage = coverageStatus(cs, metrics.avgDemand, fcSum, globalReview + lt);
      return { sku, name: skuData[sku].name, abc, xyz: abcxyz[sku]?.xyz, cell: abcxyz[sku]?.cell, lt, sl, ...metrics, cs, gap, suggestedOrder, stockMonths, coverage };
    }).sort((a, b) => { const o = { A: 0, B: 1, C: 2 }; return o[a.abc] - o[b.abc] || b.avgDemand - a.avgDemand; });
  }, [skuData, analysis, abcxyz, effectiveSeries, modelOverrides, ltOverrides, currentStock, globalLT, globalSL, globalReview, useAbcSL]);

  // FVA simulado: usa el holdout del backtest como "pasado conocido"
  const historicalFVA = useMemo(() => {
    if (!skuData || !analysis) return [];
    const records = [];
    const skuKeys = Object.keys(skuData);
    for (const sku of skuKeys) {
      const bt = analysis[sku];
      const winnerRow = bt.results.find((r) => r.key === bt.winnerKey);
      if (!winnerRow || !winnerRow.preds || bt.test.length === 0) continue;
      const holdoutDates = skuData[sku].dates.slice(-bt.holdout);
      for (let i = 0; i < bt.test.length; i++) {
        const stat = Math.max(0, winnerRow.preds[i] || 0);
        const actual = bt.test[i];
        const seed = sku.charCodeAt(sku.length - 1) * 100 + i;
        const collabIdx = Math.floor(seededRand(seed * 3) * COLLAB_DEFS.length);
        const collab = COLLAB_DEFS[collabIdx];
        const biasFactor = collab.bias + (seededRand(seed) - 0.5) * 2 * collab.noise;
        const adjusted = Math.max(0, Math.round(stat * (1 + biasFactor)));
        const dt = holdoutDates[i] || { y: 2025, m: i };
        records.push({ sku, monthKey: `${dt.y}-${String(dt.m + 1).padStart(2, "0")}`, monthLbl: monthLabel(dt), statistical: Math.round(stat * 10) / 10, adjusted, actual, collaborator: collab.name });
      }
    }
    return records;
  }, [skuData, analysis]);

  const fvaMetrics = useMemo(() => {
    const allRecords = [
      ...historicalFVA,
      ...savedAdjustments.filter((a) => a.actual != null).map((a) => ({
        sku: a.sku, monthKey: a.monthKey, monthLbl: a.monthLabel,
        statistical: a.statistical, adjusted: a.adjusted, actual: a.actual, collaborator: a.collaborator,
      })),
    ];
    if (allRecords.length === 0) return [];
    const byCollab = {};
    for (const r of allRecords) {
      if (!byCollab[r.collaborator]) byCollab[r.collaborator] = [];
      byCollab[r.collaborator].push(r);
    }
    return Object.entries(byCollab).map(([name, recs]) => {
      const totalActual = recs.reduce((s, r) => s + r.actual, 0);
      const statErr = recs.reduce((s, r) => s + Math.abs(r.actual - r.statistical), 0);
      const adjErr  = recs.reduce((s, r) => s + Math.abs(r.actual - r.adjusted), 0);
      const statWmape = totalActual > 0 ? statErr / totalActual : null;
      const adjWmape  = totalActual > 0 ? adjErr  / totalActual : null;
      const fva = statWmape != null && adjWmape != null ? statWmape - adjWmape : null;
      const improved = recs.filter((r) => Math.abs(r.actual - r.adjusted) < Math.abs(r.actual - r.statistical)).length;
      const avgBias = recs.reduce((s, r) => s + (r.adjusted - r.statistical), 0) / recs.length;
      return { name, count: recs.length, statWmape, adjWmape, fva, improved, pctImproved: improved / recs.length, avgBias };
    }).sort((a, b) => (b.fva ?? -99) - (a.fva ?? -99));
  }, [historicalFVA, savedAdjustments]);

  // Score de salud del portafolio (0-100)
  const healthScore = useMemo(() => {
    if (!skuData || !analysis || !inventoryRows) return null;
    const skus = Object.keys(skuData);
    const n = skus.length;

    // 1. Precisión del forecast (40 pts): basado en WMAPE promedio ponderado
    let wmapeSum = 0, wmapeCount = 0;
    for (const sku of skus) {
      const w = analysis[sku].results.find((r) => r.key === analysis[sku].winnerKey)?.wmape;
      if (w != null && isFinite(w)) { wmapeSum += w; wmapeCount++; }
    }
    const avgWmape = wmapeCount > 0 ? wmapeSum / wmapeCount : 0.5;
    const accuracyScore = Math.max(0, Math.min(40, 40 * (1 - avgWmape / 0.5)));

    // 2. Salud de inventario (35 pts): penaliza quiebres y excesos
    const withStock = inventoryRows.filter((r) => r.cs != null);
    let stockoutCount = 0, excessCount = 0, obsoleteCount = 0;
    for (const r of withStock) {
      const f = r.coverage?.flag;
      if (f === "stockout" || f === "low") stockoutCount++;
      else if (f === "excess") excessCount++;
      else if (f === "obsolete") obsoleteCount++;
    }
    const stockPenalty = withStock.length > 0
      ? ((stockoutCount * 1.0 + excessCount * 0.6 + obsoleteCount * 0.8) / withStock.length) * 35
      : 0;
    const inventoryScore = Math.max(0, 35 - stockPenalty);

    // 3. Estabilidad / calidad de datos (25 pts): penaliza outliers y SKUs erráticos (Z)
    let outlierFlags = 0, zCount = 0;
    for (const sku of skus) {
      if (allOutliers[sku]?.length) outlierFlags++;
      if (abcxyz[sku]?.xyz === "Z") zCount++;
    }
    const dataPenalty = ((outlierFlags * 0.5 + zCount * 0.5) / n) * 25;
    const dataScore = Math.max(0, 25 - dataPenalty);

    const total = Math.round(accuracyScore + inventoryScore + dataScore);

    const issues = [];
    if (accuracyScore < 28) issues.push({ text: `Precisión de forecast mejorable (WMAPE prom. ${(avgWmape * 100).toFixed(1)}%)`, pts: Math.round(40 - accuracyScore) });
    if (stockoutCount > 0) issues.push({ text: `${stockoutCount} SKU(s) en quiebre o cobertura crítica`, pts: Math.round((stockoutCount / Math.max(1, withStock.length)) * 35) });
    if (excessCount > 0) issues.push({ text: `${excessCount} SKU(s) con sobrestock`, pts: Math.round((excessCount / Math.max(1, withStock.length)) * 21) });
    if (obsoleteCount > 0) issues.push({ text: `${obsoleteCount} SKU(s) candidato a obsoleto`, pts: Math.round((obsoleteCount / Math.max(1, withStock.length)) * 28) });
    if (outlierFlags > 0) issues.push({ text: `${outlierFlags} SKU(s) con anomalías de datos sin limpiar`, pts: Math.round((outlierFlags / n) * 12) });
    if (zCount > 0) issues.push({ text: `${zCount} SKU(s) con demanda errática (clase Z)`, pts: Math.round((zCount / n) * 12) });
    if (withStock.length === 0) issues.push({ text: "Ingresa stock actual en Inventario para evaluar cobertura", pts: 0 });

    const grade = total >= 85 ? { label: "Excelente", color: "#0E6B63" }
      : total >= 70 ? { label: "Bueno", color: "#1A8A7A" }
      : total >= 50 ? { label: "Requiere atención", color: "#B5742A" }
      : { label: "Crítico", color: "#96402B" };

    return {
      total, grade,
      breakdown: [
        { label: "Precisión forecast", score: Math.round(accuracyScore), max: 40 },
        { label: "Salud de inventario", score: Math.round(inventoryScore), max: 35 },
        { label: "Calidad de datos", score: Math.round(dataScore), max: 25 },
      ],
      issues: issues.sort((a, b) => b.pts - a.pts),
    };
  }, [skuData, analysis, inventoryRows, allOutliers, abcxyz]);

  const portfolio = useMemo(() => {
    if (!skuData || !analysis) return null;
    let last12 = 0, fcTotal = 0;
    for (const sku in skuData) {
      const s = effectiveSeries[sku];
      last12 += s.slice(Math.max(0, s.length - 12)).reduce((a, b) => a + b, 0);
      const fc = finalForecast(s, analysis[sku].winnerKey, 24);
      if (fc) fcTotal += fc.forecastFull.slice(0, horizon).reduce((a, b) => a + b, 0);
    }
    return { last12, fcTotal, count: Object.keys(skuData).length };
  }, [skuData, analysis, effectiveSeries, horizon]);

  const futureMonthLabels = useMemo(() => {
    if (!skuData) return [];
    const skus = Object.keys(skuData);
    const lastDates = skus.map((s) => skuData[s].dates[skuData[s].dates.length - 1]);
    const allSame = lastDates.every((d) => d.y === lastDates[0].y && d.m === lastDates[0].m);
    if (allSame) return Array.from({ length: horizon }, (_, i) => monthLabel(addMonths(lastDates[0], i + 1)));
    return Array.from({ length: horizon }, (_, i) => `Mes +${i + 1}`);
  }, [skuData, horizon]);

  const summaryRows = useMemo(() => {
    if (!skuData || !analysis) return null;
    return Object.keys(skuData).map((sku) => {
      const winnerKey = analysis[sku].winnerKey;
      const usedKey = modelOverrides[sku] || winnerKey;
      const fc = finalForecast(effectiveSeries[sku], usedKey, 24);
      const wmape = analysis[sku].results.find((r) => r.key === usedKey)?.wmape;
      const last12 = skuData[sku].series.slice(-12).reduce((a, b) => a + b, 0);
      const upliftMap = promoFuture[sku] || {};
      const monthly = fc ? fc.forecastFull.slice(0, horizon).map((v, i) => upliftMap[i] ? Math.round(v * (1 + upliftMap[i])) : v) : [];
      const total = monthly.reduce((a, b) => a + b, 0);
      const hasPromo = Object.keys(upliftMap).some((k) => k < horizon && upliftMap[k]);
      return {
        sku,
        name: skuData[sku].name,
        modelLabel: MODEL_DEFS.find((m) => m.key === usedKey)?.label || usedKey,
        isWinner: usedKey === winnerKey,
        wmape,
        last12,
        monthly,
        total,
        hasPromo,
      };
    });
  }, [skuData, analysis, modelOverrides, horizon, effectiveSeries, promoFuture]);

  // Top-down: desagrega el forecast de cada SKU a las sucursales según su mezcla histórica
  const branchBreakdown = useMemo(() => {
    if (!skuData || !analysis || !branches || !summaryRows) return null;
    const rows = [];
    for (const row of summaryRows) {
      const mix = skuData[row.sku].branchMix;
      if (!mix) continue;
      for (const branch of branches) {
        const share = mix[branch] || 0;
        const monthly = row.monthly.map((v) => Math.round(v * share));
        const total = monthly.reduce((a, b) => a + b, 0);
        rows.push({ sku: row.sku, name: row.name, branch, share, monthly, total });
      }
    }
    return rows;
  }, [skuData, analysis, branches, summaryRows]);

  // Totales por sucursal (suma de todos los SKU)
  const branchTotals = useMemo(() => {
    if (!branchBreakdown || !branches) return null;
    return branches.map((branch) => {
      const rows = branchBreakdown.filter((r) => r.branch === branch);
      const total = rows.reduce((a, r) => a + r.total, 0);
      return { branch, total, skuCount: rows.filter((r) => r.total > 0).length };
    }).sort((a, b) => b.total - a.total);
  }, [branchBreakdown, branches]);

  const aggregateSeries = useMemo(() => {
    if (!skuData || !analysis) return null;
    if (chartSku === "TOTAL") {
      const histMap = new Map();
      for (const sku in skuData) {
        const { dates } = skuData[sku];
        const series = effectiveSeries[sku];
        dates.forEach((d, i) => {
          const key = d.y * 12 + d.m;
          if (!histMap.has(key)) histMap.set(key, { date: d, value: 0 });
          histMap.get(key).value += series[i];
        });
      }
      const historyPoints = Array.from(histMap.values()).sort((a, b) => a.date.y * 12 + a.date.m - (b.date.y * 12 + b.date.m));
      const globalLastKey = Math.max(
        ...Object.keys(skuData).map((s) => {
          const d = skuData[s].dates[skuData[s].dates.length - 1];
          return d.y * 12 + d.m;
        })
      );
      const fcMap = new Map();
      for (const sku in skuData) {
        const usedKey = modelOverrides[sku] || analysis[sku].winnerKey;
        const fc = finalForecast(skuData[sku].series, usedKey, 24);
        if (!fc) continue;
        const lastDate = skuData[sku].dates[skuData[sku].dates.length - 1];
        for (let i = 0; i < 24; i++) {
          const d = addMonths(lastDate, i + 1);
          const key = d.y * 12 + d.m;
          if (key <= globalLastKey) continue;
          if (!fcMap.has(key)) fcMap.set(key, { date: d, value: 0 });
          fcMap.get(key).value += fc.forecastFull[i];
        }
      }
      const forecastPoints = Array.from(fcMap.values())
        .sort((a, b) => a.date.y * 12 + a.date.m - (b.date.y * 12 + b.date.m))
        .slice(0, horizon);
      return { historyPoints, forecastPoints };
    }
    const sku = chartSku;
    if (!skuData[sku]) return null;
    const { dates } = skuData[sku];
    const series = effectiveSeries[sku];
    const usedKey = modelOverrides[sku] || analysis[sku].winnerKey;
    const fc = finalForecast(series, usedKey, 24);
    const historyPoints = dates.map((d, i) => ({ date: d, value: series[i] }));
    const lastDate = dates[dates.length - 1];
    const forecastPoints = fc
      ? Array.from({ length: horizon }, (_, i) => ({ date: addMonths(lastDate, i + 1), value: fc.forecastFull[i] }))
      : [];
    return { historyPoints, forecastPoints };
  }, [skuData, analysis, modelOverrides, chartSku, horizon]);

  const aggChartData = useMemo(() => {
    if (!aggregateSeries) return null;
    const data = aggregateSeries.historyPoints.map((p) => ({ month: monthLabel(p.date), real: Math.round(p.value * 10) / 10, forecast: null }));
    aggregateSeries.forecastPoints.forEach((p) => data.push({ month: monthLabel(p.date), real: null, forecast: Math.round(p.value * 10) / 10 }));
    return data;
  }, [aggregateSeries]);

  function exportSummaryCsv() {
    if (!summaryRows) return;
    const header = ["SKU", "Nombre", "Modelo", "WMAPE", ...futureMonthLabels, "Total horizonte"];
    const lines = [header.join(",")];
    for (const row of summaryRows) {
      const vals = [
        row.sku,
        `"${row.name}"`,
        `"${row.modelLabel}"`,
        row.wmape != null ? `${(row.wmape * 100).toFixed(1)}%` : "",
        ...row.monthly.map((v) => Math.round(v * 10) / 10),
        Math.round(row.total * 10) / 10,
      ];
      lines.push(vals.join(","));
    }
    const blob = new Blob([lines.join("\n")], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "forecast_resumen.csv";
    a.click();
    URL.revokeObjectURL(url);
  }

