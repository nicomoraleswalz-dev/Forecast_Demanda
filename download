const LIFECYCLE = {
  nuevo:        { label: "Nuevo lanzamiento", color: "#1E5FA8", icon: "🌱", desc: "Historia corta. Forecast con cautela, considerar análogo." },
  crecimiento:  { label: "Crecimiento",       color: "#0E6B63", icon: "📈", desc: "Tendencia al alza sostenida. Modelo con tendencia (Holt)." },
  maduro:       { label: "Maduro",            color: "#2E343A", icon: "➡️", desc: "Demanda estable. Modelo estacional clásico." },
  declive:      { label: "Declive",           color: "#B5742A", icon: "📉", desc: "Tendencia a la baja. Revisar surtido y stock." },
  errático:     { label: "Errático/Intermitente", color: "#96402B", icon: "⚡", desc: "Alta variabilidad o intermitente. Croston / Min-Max." },
  descontinuar: { label: "Candidato a discontinuar", color: "#9AA5B1", icon: "⛔", desc: "Sin demanda reciente. Evaluar baja del catálogo." },
};

function detectLifecycle(series, dates) {
  const n = series.length;
  const nonZero = series.filter((v) => v > 0);

  // Sin movimiento reciente → descontinuar
  const recent6 = series.slice(Math.max(0, n - 6));
  if (recent6.every((v) => v === 0)) return { stage: "descontinuar", confidence: "alta" };

  // Historia corta → nuevo lanzamiento
  if (n < 12 || nonZero.length < 8) return { stage: "nuevo", confidence: n < 8 ? "alta" : "media" };

  // Intermitencia: muchos ceros
  const zeroRatio = series.filter((v) => v === 0).length / n;
  if (zeroRatio > 0.35) return { stage: "errático", confidence: "alta" };

  // CV alto → errático
  const m = mean(nonZero);
  const cv = m > 0 ? Math.sqrt(nonZero.reduce((a, v) => a + (v - m) ** 2, 0) / nonZero.length) / m : 999;

  // Tendencia: comparar primer tercio vs último tercio
  const third = Math.floor(n / 3);
  const firstAvg = mean(series.slice(0, third));
  const lastAvg = mean(series.slice(n - third));
  const growth = firstAvg > 0 ? (lastAvg - firstAvg) / firstAvg : 0;

  if (cv > 0.85) return { stage: "errático", confidence: "media", cv, growth };
  if (growth > 0.20) return { stage: "crecimiento", confidence: growth > 0.4 ? "alta" : "media", cv, growth };
  if (growth < -0.20) return { stage: "declive", confidence: growth < -0.4 ? "alta" : "media", cv, growth };
  return { stage: "maduro", confidence: "alta", cv, growth };
}

// Modelo recomendado por etapa de ciclo de vida
function recommendedModelForStage(stage) {
  switch (stage) {
    case "crecimiento": return "holt";
    case "declive":     return "holt";
    case "errático":    return "croston";
    case "maduro":      return "hw";
    case "nuevo":       return "ses";
    default:            return null;
  }
}

