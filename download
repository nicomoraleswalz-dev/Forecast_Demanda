/* ============================================================
   INVENTARIO: STOCK DE SEGURIDAD + PUNTO DE REORDEN
   ============================================================ */
const Z_TABLE = { 80: 0.842, 85: 1.036, 90: 1.282, 95: 1.645, 98: 2.054, 99: 2.326, 99.5: 2.576 };
const SL_BY_ABC = { A: 99, B: 95, C: 90 };

function calcInventory(series, forecast12, lt, sl, reviewPeriod) {
  const last12 = series.slice(Math.max(0, series.length - 12));
  const nonZero = last12.filter((v) => v > 0);
  const avgDemand = last12.length > 0 ? mean(last12) : 0;
  const avgDemandNZ = nonZero.length > 0 ? mean(nonZero) : 0;
  const variance = last12.length > 1
    ? last12.reduce((acc, v) => acc + (v - avgDemand) ** 2, 0) / last12.length : 0;
  const stdDev = Math.sqrt(variance);

  const avgFc = forecast12 && forecast12.length > 0 ? mean(forecast12.slice(0, Math.min(3, forecast12.length))) : avgDemand;

  const z = Z_TABLE[sl] || 1.645;
  const ss = Math.max(0, Math.round(z * stdDev * Math.sqrt(lt)));
  const rop = Math.round(avgDemand * lt + ss);
  const maxStock = Math.round(avgDemand * (lt + reviewPeriod) + ss);
  const minStock = ss;
  const coverage = avgDemand > 0 ? (rop / avgDemand).toFixed(1) : "—";

  return { avgDemand, avgDemandNZ, stdDev, ss, rop, maxStock, minStock, avgFc, coverage, z, sl };
}

function classifyABCXYZ(skuData) {
  const skus = Object.keys(skuData);
  const stats = skus.map((sku) => {
    const s = skuData[sku].series;
    const last = s.slice(Math.max(0, s.length - 12));
    const total = last.reduce((a, b) => a + b, 0);
    const nonZero = last.filter((v) => v > 0);
    const m = nonZero.length > 0 ? mean(nonZero) : 0;
    const variance = nonZero.length > 1
      ? nonZero.reduce((acc, v) => acc + (v - m) ** 2, 0) / nonZero.length : 0;
    const cv = m > 0 ? Math.sqrt(variance) / m : 999;
    return { sku, total, cv };
  });

  const totalSum = stats.reduce((a, b) => a + b.total, 0);
  const sorted = [...stats].sort((a, b) => b.total - a.total);
  let cumPct = 0;
  const abc = {};
  for (const s of sorted) {
    cumPct += totalSum > 0 ? s.total / totalSum : 1 / skus.length;
    abc[s.sku] = cumPct <= 0.8 ? "A" : cumPct <= 0.95 ? "B" : "C";
  }
  const xyz = {};
  for (const s of stats) xyz[s.sku] = s.cv < 0.5 ? "X" : s.cv < 1.0 ? "Y" : "Z";

  return stats.reduce((acc, s) => {
    acc[s.sku] = {
      abc: abc[s.sku], xyz: xyz[s.sku],
      cell: abc[s.sku] + xyz[s.sku],
      cv: s.cv, total: s.total,
      pct: totalSum > 0 ? s.total / totalSum : 0,
    };
    return acc;
  }, {});
}

