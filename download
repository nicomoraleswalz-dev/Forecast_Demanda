  const [selectedCollab, setSelectedCollab] = useState(COLLAB_DEFS[0].name);
  const [newCollabInput, setNewCollabInput] = useState("");
  const [savedAdjustments, setSavedAdjustments] = useState([]);   // {id,sku,monthKey,monthLabel,statistical,adjusted,collaborator,comment,actual}
  const [adjInputs, setAdjInputs] = useState({});                 // {monthKey: {value, comment}}
  const [fvaSku, setFvaSku] = useState(null);
  // Promociones: { sku: Set(indices históricos marcados como promo) }
  const [promoHist, setPromoHist] = useState({});
  // Uplift futuro: { sku: { monthOffset: pct } }  ej {0: 0.3} = +30% el mes +1
  const [promoFuture, setPromoFuture] = useState({});
  const [promoSku, setPromoSku] = useState(null);
  // Top-down por sucursal
  const [branches, setBranches] = useState(null);   // lista de sucursales (del CSV o demo)
  const [branchView, setBranchView] = useState("ALL");

  const allOutliers = useMemo(() => {
    if (!skuData) return {};
    const out = {};
    for (const sku in skuData) out[sku] = detectOutliers(skuData[sku].series);
