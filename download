    reader.readAsText(file);
    e.target.value = "";
  }

  const currentSku = selectedSku;
  const currentSeries = skuData && currentSku ? effectiveSeries[currentSku] : null;
  const currentSeriesRaw = skuData && currentSku ? skuData[currentSku].series : null;
  const currentDates = skuData && currentSku ? skuData[currentSku].dates : null;
  const currentOutliers = currentSku ? (allOutliers[currentSku] || []) : [];
  const currentClean = !!(currentSku && useCleanData[currentSku]);
  const currentBacktest = analysis && currentSku ? analysis[currentSku] : null;
  const usedModelKey = currentSku ? (modelOverrides[currentSku] || (currentBacktest ? currentBacktest.winnerKey : "naive")) : null;

  const finalFc = useMemo(() => {
    if (!currentSeries || !usedModelKey) return null;
    const base = finalForecast(currentSeries, usedModelKey, 24);
    if (!base) return null;
    // Aplicar uplift de promociones futuras
    const upliftMap = promoFuture[currentSku] || {};
    if (Object.keys(upliftMap).length > 0) {
      const adjusted = base.forecastFull.map((v, i) => {
        const up = upliftMap[i];
        return up ? Math.round(v * (1 + up)) : v;
      });
      return { ...base, forecastFull: adjusted, baseForecast: base.forecastFull, hasPromo: true };
    }
    return { ...base, baseForecast: base.forecastFull, hasPromo: false };
  }, [currentSeries, usedModelKey, promoFuture, currentSku]);

  const currentSigma = useMemo(() => {
    if (!currentSeries || !finalFc) return null;
    return residualStd(currentSeries, finalFc.fittedHistory);
  }, [currentSeries, finalFc]);

  const chartData = useMemo(() => {
    if (!currentDates || !currentSeries || !finalFc) return null;
    return buildChartData(currentDates, currentSeries, finalFc, horizon, currentSigma);
  }, [currentDates, currentSeries, finalFc, horizon, currentSigma]);

  const usedResultRow = currentBacktest && usedModelKey
    ? currentBacktest.results.find((r) => r.key === usedModelKey) : null;

  const horizonTotal = finalFc ? finalFc.forecastFull.slice(0, horizon).reduce((a, b) => a + b, 0) : null;

  const sortedResults = currentBacktest
    ? [...currentBacktest.results].sort((a, b) => {
        if (a.insufficient && !b.insufficient) return 1;
        if (!a.insufficient && b.insufficient) return -1;
        if (a.insufficient && b.insufficient) return 0;
        return a.wmape - b.wmape;
      })
    : [];

  const backtestKey = (currentSku && backtestView[currentSku]) || usedModelKey;
  const backtestRow = currentBacktest ? currentBacktest.results.find((r) => r.key === backtestKey) : null;
  const backtestDates = currentDates && currentBacktest ? currentDates.slice(currentDates.length - currentBacktest.holdout) : null;

  return (
    <div style={{ background: COLORS.bg, minHeight: "100vh" }} className="w-full">
      {/* HEADER */}
      <div className="border-b px-6 py-5" style={{ borderColor: COLORS.border, background: COLORS.panel }}>
        <Eyebrow>demand planning · sku agregado · salud + intervalos</Eyebrow>
        <div className="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
