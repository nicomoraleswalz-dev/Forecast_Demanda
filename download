      setBacktestView({});
      setCsvError(null);
      setChartSku("TOTAL");
      setUseCleanData({});
      setLtOverrides({});
      setCurrentStock({});
      setSavedAdjustments([]);
      setAdjInputs({});
      setFvaSku(Object.keys(res.data)[0]);
      setPromoHist({});
      setPromoFuture({});
      setPromoSku(Object.keys(res.data)[0]);
      setBranches(res.branches || null);
      setBranchView("ALL");
