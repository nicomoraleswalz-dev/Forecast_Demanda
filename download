/* ============================================================
   MÉTRICAS DE ERROR
   ============================================================ */
function calcErrors(actual, predicted) {
  const n = actual.length;
  let sumAbsErr = 0, sumSqErr = 0, sumErr = 0, sumAbsActual = 0;
  for (let i = 0; i < n; i++) {
    const err = actual[i] - predicted[i];
    sumAbsErr += Math.abs(err);
    sumSqErr += err * err;
    sumErr += err;
    sumAbsActual += Math.abs(actual[i]);
  }
  return {
    mae: sumAbsErr / n,
    rmse: Math.sqrt(sumSqErr / n),
    bias: sumErr / n,
    wmape: sumAbsActual > 0 ? sumAbsErr / sumAbsActual : null,
  };
}
function sseFromFitted(y, fitted, startIdx) {
  let s = 0;
  for (let t = startIdx; t < y.length; t++) if (fitted[t] != null) s += Math.pow(y[t] - fitted[t], 2);
  return s;
}

/* ============================================================
   MODELOS DE FORECAST (implementación de bajo nivel)
   ============================================================ */
function sesFit(y, alpha) {
  const n = y.length;
  const level = new Array(n);
  const fitted = new Array(n).fill(null);
  level[0] = y[0];
  for (let t = 1; t < n; t++) {
    fitted[t] = level[t - 1];
    level[t] = alpha * y[t] + (1 - alpha) * level[t - 1];
  }
  const last = level[n - 1];
  return { fitted, forecast: (h) => Array.from({ length: h }, () => last) };
}

function holtFit(y, alpha, beta) {
  const n = y.length;
  if (n < 3) return null;
  const level = new Array(n), trend = new Array(n);
  const fitted = new Array(n).fill(null);
  level[0] = y[0];
  trend[0] = y[1] - y[0];
  if (n > 1) fitted[1] = level[0] + trend[0];
  for (let t = 1; t < n; t++) {
    const pl = level[t - 1], pt = trend[t - 1];
    const nl = alpha * y[t] + (1 - alpha) * (pl + pt);
    const nt = beta * (nl - pl) + (1 - beta) * pt;
    level[t] = nl; trend[t] = nt;
    if (t + 1 < n) fitted[t + 1] = nl + nt;
  }
  const ll = level[n - 1], lt = trend[n - 1];
  return { fitted, forecast: (h) => Array.from({ length: h }, (_, i) => ll + (i + 1) * lt) };
}

function hwFit(y, alpha, beta, gamma, m) {
  const n = y.length;
  if (n < 2 * m) return null;
  const s1 = y.slice(0, m), s2 = y.slice(m, 2 * m);
  const a1 = mean(s1), a2 = mean(s2);
  let lvl = a1, tr = (a2 - a1) / m;
  const seasonal = s1.map((v) => v - a1);
  const fitted = new Array(n).fill(null);
  for (let t = 0; t < n; t++) {
    const sTm = t < m ? seasonal[t] : seasonal[t - m];
    if (t >= 1) fitted[t] = lvl + tr + sTm;
    const nl = alpha * (y[t] - sTm) + (1 - alpha) * (lvl + tr);
    const nt = beta * (nl - lvl) + (1 - beta) * tr;
    const ns = gamma * (y[t] - nl) + (1 - gamma) * sTm;
    lvl = nl; tr = nt;
    seasonal[t] = ns;
  }
  const lastSeasonals = seasonal.slice(n - m, n);
  return {
    fitted,
    forecast: (h) => Array.from({ length: h }, (_, i) => lvl + (i + 1) * tr + lastSeasonals[i % m]),
  };
}

function linearFit(y) {
  const n = y.length;
  const tArr = Array.from({ length: n }, (_, i) => i);
  const tMean = mean(tArr), yMean = mean(y);
  let num = 0, den = 0;
  for (let i = 0; i < n; i++) { num += (tArr[i] - tMean) * (y[i] - yMean); den += (tArr[i] - tMean) ** 2; }
  const b = den === 0 ? 0 : num / den;
  const a = yMean - b * tMean;
  const fitted = tArr.map((t) => a + b * t);
  return { a, b, fitted, forecast: (h) => Array.from({ length: h }, (_, i) => a + b * (n + i)) };
}

function crostonFit(y, alpha) {
  const nzIdx = [];
  for (let t = 0; t < y.length; t++) if (y[t] > 0) nzIdx.push(t);
  if (nzIdx.length < 2) return null;
  let Z = y[nzIdx[0]];
  let P = nzIdx[0] + 1;
  for (let i = 1; i < nzIdx.length; i++) {
    const interval = nzIdx[i] - nzIdx[i - 1];
    Z = alpha * y[nzIdx[i]] + (1 - alpha) * Z;
    P = alpha * interval + (1 - alpha) * P;
  }
  const val = (Z / P) * (1 - alpha / 2);
  return { fitted: new Array(y.length).fill(null), forecast: (h) => Array.from({ length: h }, () => val) };
}

/* ============================================================
   DETECCIÓN DE OUTLIERS (IQR + quiebres de stock)
   ============================================================ */
function detectOutliers(series) {
  const n = series.length;
  const nonZero = series.filter((v) => v > 0);
  if (nonZero.length < 4) return [];
  const sorted = [...nonZero].sort((a, b) => a - b);
  const q1 = sorted[Math.floor(sorted.length * 0.25)];
  const q3 = sorted[Math.floor(sorted.length * 0.75)];
  const iqr = q3 - q1;
  const upper = q3 + 2.0 * iqr;
  const lower = Math.max(0, q1 - 2.0 * iqr);
  const meanNZ = mean(nonZero);
  const zeroStreak = 3; // ≥3 ceros seguidos = posible quiebre de stock

  const flags = [];
  let zeros = 0;
  for (let i = 0; i < n; i++) {
    const v = series[i];
    if (v === 0) {
      zeros++;
      if (zeros === zeroStreak && meanNZ > 5) {
        flags.push({ index: i - zeroStreak + 1, endIndex: i, type: "stockout", label: "Posible quiebre de stock" });
      }
    } else {
      zeros = 0;
      if (v > upper) flags.push({ index: i, type: "high", label: `Pico atípico (>${fmt(upper, 0)})` });
      else if (v < lower && lower > 0) flags.push({ index: i, type: "low", label: `Valle atípico (<${fmt(lower, 0)})` });
    }
  }
  return flags;
}

function applyClean(series, outliers) {
  const clean = [...series];
  for (const f of outliers) {
    if (f.type === "stockout") {
      for (let k = f.index; k <= (f.endIndex || f.index); k++) {
        const prev = k > 0 ? clean[k - 1] : null;
        const next = k < clean.length - 1 ? series[k + 1] : null;
        if (prev != null && next != null) clean[k] = Math.round((prev + next) / 2);
        else if (prev != null) clean[k] = prev;
        else clean[k] = series[k];
      }
    } else {
      const i = f.index;
      const prev = i > 0 ? series[i - 1] : null;
      const next = i < series.length - 1 ? series[i + 1] : null;
      if (prev != null && next != null) clean[i] = Math.round((prev + next) / 2);
      else if (prev != null) clean[i] = prev;
      else clean[i] = Math.round(mean(series.filter((v) => v > 0)));
    }
  }
  return clean;
}

